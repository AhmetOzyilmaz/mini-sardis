{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "description": "Sardis Subscription Management System — HTTP, Auth, JVM, and Business metrics across all microservices",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sardis", "microservices"],
  "timezone": "browser",
  "title": "Sardis — Service Overview",
  "uid": "sardis-overview-v1",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": { "text": "subscription-service", "value": "subscription-service" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(up, application)",
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "name": "application",
        "options": [],
        "query": { "query": "label_values(up, application)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [

    {
      "collapsed": false,
      "id": 100,
      "type": "row",
      "title": "HTTP Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5xx %)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"5..\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count{application=\"$application\"}[$__rate_interval]))",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Latency p99",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "4xx Rate",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by(uri, method, status) (rate(http_server_requests_seconds_count{application=\"$application\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Latency Percentiles",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "collapsed": false,
      "id": 200,
      "type": "row",
      "title": "Auth Business Metrics (Subscription Service)",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },

    {
      "id": 21,
      "type": "stat",
      "title": "Login Success / sec",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(auth_login_attempts_total{application=\"subscription-service\",result=\"success\"}[$__rate_interval]))",
          "legendFormat": "success/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 22,
      "type": "stat",
      "title": "Login Failures / sec",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(auth_login_attempts_total{application=\"subscription-service\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "failure/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 23,
      "type": "stat",
      "title": "Registrations / sec",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(auth_register_attempts_total{application=\"subscription-service\"}[$__rate_interval]))",
          "legendFormat": "register/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 24,
      "type": "timeseries",
      "title": "Auth Event Trends",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(auth_login_attempts_total{application=\"subscription-service\",result=\"success\"}[$__rate_interval])",
          "legendFormat": "Login success",
          "refId": "A"
        },
        {
          "expr": "rate(auth_login_attempts_total{application=\"subscription-service\",result=\"failure\"}[$__rate_interval])",
          "legendFormat": "Login failure",
          "refId": "B"
        },
        {
          "expr": "rate(auth_register_attempts_total{application=\"subscription-service\",result=\"success\"}[$__rate_interval])",
          "legendFormat": "Register success",
          "refId": "C"
        },
        {
          "expr": "rate(auth_register_attempts_total{application=\"subscription-service\",result=\"failure\"}[$__rate_interval])",
          "legendFormat": "Register failure",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "collapsed": false,
      "id": 300,
      "type": "row",
      "title": "JVM Health",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "type": "gauge",
      "title": "Heap Utilization %",
      "gridPos": { "x": 0, "y": 37, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(jvm_memory_used_bytes{application=\"$application\",area=\"heap\"}) / sum(jvm_memory_max_bytes{application=\"$application\",area=\"heap\"})",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "JVM Memory (Heap vs Non-Heap)",
      "gridPos": { "x": 6, "y": 37, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"$application\",area=\"heap\"}) by (application)",
          "legendFormat": "Heap used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"$application\",area=\"heap\"}) by (application)",
          "legendFormat": "Heap max",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"$application\",area=\"nonheap\"}) by (application)",
          "legendFormat": "Non-heap used",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "id": 33,
      "type": "timeseries",
      "title": "GC Pause Duration",
      "gridPos": { "x": 0, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$application\"}[$__rate_interval])",
          "legendFormat": "{{action}} {{cause}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "id": 34,
      "type": "timeseries",
      "title": "JVM Threads",
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$application\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$application\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"$application\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "collapsed": false,
      "id": 400,
      "type": "row",
      "title": "Infrastructure",
      "gridPos": { "x": 0, "y": 53, "w": 24, "h": 1 }
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "HikariCP Connection Pool",
      "gridPos": { "x": 0, "y": 54, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$application\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$application\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"$application\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"$application\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 12, "y": 54, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$application\"}",
          "legendFormat": "Process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"$application\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "collapsed": true,
      "id": 500,
      "type": "row",
      "title": "Business Events — Future (shows No Data until services are implemented)",
      "gridPos": { "x": 0, "y": 62, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 51,
          "type": "stat",
          "title": "Outbox Events Unprocessed",
          "description": "Alert if > 100 — indicates OutboxPoller is down or lagging",
          "gridPos": { "x": 0, "y": 63, "w": 8, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "targets": [
            {
              "expr": "outbox_events_unprocessed{application=\"subscription-service\"}",
              "legendFormat": "Unprocessed",
              "refId": "A"
            }
          ],
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "none"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 50 },
                  { "color": "red", "value": 100 }
                ]
              }
            },
            "overrides": []
          }
        },

        {
          "id": 52,
          "type": "stat",
          "title": "Payment Success Rate %",
          "gridPos": { "x": 8, "y": 63, "w": 8, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "targets": [
            {
              "expr": "100 * sum(rate(payment_result_total{status=\"SUCCESS\"}[$__rate_interval])) / sum(rate(payment_result_total[$__rate_interval]))",
              "legendFormat": "Success %",
              "refId": "A"
            }
          ],
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "none"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 90 },
                  { "color": "green", "value": 98 }
                ]
              }
            },
            "overrides": []
          }
        },

        {
          "id": 53,
          "type": "stat",
          "title": "Notifications Sent / sec",
          "gridPos": { "x": 16, "y": 63, "w": 8, "h": 4 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "targets": [
            {
              "expr": "sum(rate(notification_sent_total{success=\"true\"}[$__rate_interval]))",
              "legendFormat": "sent/s",
              "refId": "A"
            }
          ],
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "thresholds": {
                "mode": "absolute",
                "steps": [{ "color": "blue", "value": null }]
              }
            },
            "overrides": []
          }
        }
      ]
    }

  ]
}
